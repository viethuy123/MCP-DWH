# =============================================================================
# DATABASE — lấy từ postgres docker-compose
# =============================================================================
DB_HOST=dwh_postgres        # service name trong dev-network
DB_PORT=5432                # internal port (không phải 5433)
DB_NAME=postgres
DB_USER=dev_user
DB_PASSWORD=dev_password

# =============================================================================
# MCP SERVER
# =============================================================================
MCP_HOST=0.0.0.0
MCP_PORT=8000

# =============================================================================
# DBT
# =============================================================================
DBT_MANIFEST_PATH=dbt/manifest.json
